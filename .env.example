# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=8001
FLASK_DEBUG=false

# RAG proxy (例如: http://127.0.0.1:8001/rag/query 或 指向实际RAG服务)
RAG_PROXY_URL=
RAG_TIMEOUT=120

# 本地 RAG 项目路径（用于直接 import rag_query）
RAG_PROJECT_PATH=

# RAG 运行模式（默认本地全量）
RAG_LOCAL_MODE=true

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Embedding 模型
EMBEDDING_MODEL_TYPE=biencoder
BIENCODER_MODEL_PATH=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120

# 输入解析（OpenAI 兼容）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# 答案生成（OpenAI / Ollama）
LLM_PROVIDER=openai
LLM_API_BASE=https://api.openai.com
LLM_API_KEY=
LLM_MODEL=gpt-3.5-turbo
LLM_TIMEOUT=60
