# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=8001
FLASK_DEBUG=false

# RAG proxy (例如: http://127.0.0.1:8001/rag/query 或 指向实际RAG服务)
RAG_PROXY_URL=
RAG_TIMEOUT=120

# 本地 RAG 项目路径（用于直接 import rag_query）
RAG_PROJECT_PATH=

# 轻量 RAG（默认启用）
RAG_LIGHT_MODE=true
RAG_LIGHT_DATA_PATH=

# 云端 LLM API（OpenAI 兼容）
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=gpt-3.5-turbo
LLM_TIMEOUT=60
