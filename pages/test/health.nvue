<template>
  <view class="container">
    <text class="title">数据同步666</text>

    <view class="btn-group">
      <button class="btn" type="primary" @click="doInit">
        1. 初始化 OPPO SDK
      </button>
      <button class="btn" type="primary" @click="doAuth">
        2. 请求健康数据授权
      </button>
      <button class="btn" type="primary" @click="doReadHeartRate">
        3. 读取最近心率数据
      </button>
    </view>

    <view class="log-box">
      <text class="log-title">运行日志：</text>
      <text class="log-content">{{ statusMsg }}</text>
    </view>

    <view class="data-box">
      <text class="data-text">{{ healthDataJson }}</text>
    </view>
  </view>
</template>

<script>
// 1. 标准写法：在全局作用域引入插件，确保页面一加载就能拿到引用

export default {
  data() {
    return {
      statusMsg: "等待操作...\n",
      heartRateData: "暂无数据",
      healthDataJson: null,
      category: ["STEP_COUNT", "DAILY_ACTIVITY_DETAIL", "BLOOD_PRESSURE_COUNT", "BLOOD_PRESSURE_DETAIL"],
      index: 0
    };
  },
  methods: {
    // 新增：模拟控制台输出的辅助函数，将新消息拼接到尾部
    appendLog(msg) {
      // 获取当前时间戳 HH:mm:ss
      const time = new Date().toTimeString().split(" ")[0];
      const logStr = `[${time}] ${msg}\n`;
      this.statusMsg = logStr;
      // 同时也输出到 HBuilderX 的真实控制台，方便双端对照
      console.log(`[OppoHealth] ${msg}`);
    },

    // 1. 初始化 SDK
    doInit() {
      try {
        this.oppoHealth = uni.requireNativePlugin("OppoHealthModule");

        if (!this.oppoHealth) {
          this.appendLog(
            "❌ 插件未加载，请确认混淆规则或 dcloud_uniplugins.json"
          );
          return;
        }

        this.appendLog("▶️ 准备调用 initSdk...");

        this.oppoHealth.initSdk((res) => {
          this.appendLog("✅ 初始化回调返回: " + res);
        });
      } catch (e) {
        this.appendLog("❌ 调用 initSdk 出现 JS 异常: " + e.message);
      }
    },

    // 2. 请求授权
    // 2. 请求授权
    doAuth() {
      if (!this.oppoHealth) return this.error("插件未加载");

      this.appendLog("▶️ 准备拉起授权页 requestAuth...");
      try {
        this.oppoHealth.requestAuth((code) => {
          this.appendLog("⬇️ 收到授权回调，Code:", code);

          if (code === 100000) {
            this.appendLog("✅ 授权成功 (100000)");
          } else if (code === 100007) {
            this.appendLog("❌ 健康 app 未安装 (100007)");

            // 👇 新增：优雅地引导用户去下载
            uni.showModal({
              title: "需要安装健康App",
              content:
                "为了同步您的健康数据，需要配合“欢太健康”App使用。是否立即前往安装？",
              confirmText: "去安装",
              cancelText: "取消",
              success: (res) => {
                if (res.confirm) {
                  this.appendLog("▶️ 用户同意安装，正在拉起商店/浏览器...");
                  // 调用我们在第二步写的 Java 原生方法
                  this.oppoHealth.goToInstallHealthApp();
                }
              },
            });
          } else if (code === 100014) {
            this.appendLog("⚠️ 用户取消了授权 (100014)");
          } else {
            this.appendLog("❌ 授权失败，未知错误");
          }
        });
      } catch (e) {
        this.appendLog("❌ 调用 requestAuth 出现 JS 异常:", e.message);
      }
    },

    // 3. 读取心率数据
    doReadHeartRate() {
      if (!this.oppoHealth) return this.appendLog("❌ 插件未加载");

      this.appendLog("▶️ 准备调用 readHeartRate...");
      try {
        // 调用你新写的万能 Java 接口
        let typeStr = this.category[this.index % this.category.length];
        let label = typeStr.replace(/_/g, " ");
        let queryDays = 7; // 查询最近7天的数据
        this.index += 1; // 每次调用切换数据类型，方便测试多个接口

        this.oppoHealth.readHealthData(typeStr, queryDays, (res) => {
          if (typeof res === "number") {
            this.appendLog(`❌ 读取 [${label}] 失败，错误码: ${res}`);
            this.healthDataJson = `读取失败，错误码: ${res}`;
          } else {
            this.appendLog(`✅ 读取 [${label}] 成功，准备解析...`);
            
            try {
              const dataObj = JSON.parse(res);
              this.appendLog(`✅ JSON 解析成功: 共 ${dataObj.length || 0} 条数据点`);
              // 格式化展示 JSON，加上 2 个空格的缩进使其在界面上更易读
              this.healthDataJson = JSON.stringify(dataObj, null, 2);
              this.healthDataJson += `\n\n（显示了最近 ${queryDays} 天的 ${label} 数据）`;
            } catch (e) {
              this.appendLog(`❌ JSON 解析异常: ${e.message}`);
              this.healthDataJson = res; // 解析失败则展示原始字符串
            }
          }
        });
      } catch (e) {
        this.appendLog(`❌ readHealthData JS 异常: ${e.message}`);
      }
    },
  },
};
</script>

<style scoped>
.container {
  flex: 1;
  padding: 40rpx;
  background-color: #f5f5f5;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 50rpx;
  color: #333;
}

.btn-group {
  margin-bottom: 40rpx;
}

.btn {
  margin-bottom: 20rpx;
  font-size: 32rpx;
}

.log-box {
  height: 400rpx; /* 固定高度，方便滚动 */
  background-color: #ffffff;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
  border: 1px solid #ddd;
}

.log-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
  margin-bottom: 10rpx;
}

.log-content {
  margin-top: 20rpx;
  font-size: 36rpx;
  color: #007aff;
  line-height: 40rpx;
}

.data-box {
  flex: 1;
  background-color: #282c34;
  padding: 20rpx;
  border-radius: 12rpx;
}

.data-text {
  font-size: 24rpx;
  color: #98c379;
  font-family: monospace;
}
</style>