<template>
    <view class="container">
        <text class="title">健康与用药 Agent - 数据同步</text>

        <view class="btn-group">
            <button class="btn" type="primary" @click="doInit">1. 初始化 OPPO SDK</button>
            <button class="btn" type="primary" @click="doAuth">2. 请求健康数据授权</button>
            <button class="btn" type="primary" @click="doReadHeartRate">3. 读取最近心率数据</button>
        </view>

        <scroll-view class="log-box" scroll-y="true">
            <text class="log-title">运行日志：</text>
            <text class="log-content">{{ statusMsg }}</text>
        </scroll-view>

        <scroll-view class="data-box" scroll-y="true">
            <text class="data-text">{{ heartRateData }}</text>
        </scroll-view>
    </view>
</template>

<script>
// 1. 标准写法：在全局作用域引入插件，确保页面一加载就能拿到引用
const oppoHealth = uni.requireNativePlugin('OppoHealthModule');

export default {
    data() {
        return {
            statusMsg: '等待操作...\n',
            heartRateData: '暂无数据'
        };
    },
    methods: {
        // 新增：模拟控制台输出的辅助函数，将新消息拼接到尾部
        appendLog(msg) {
            // 获取当前时间戳 HH:mm:ss
            const time = new Date().toTimeString().split(' ')[0];
            const logStr = `[${time}] ${msg}\n`;
            this.statusMsg += logStr;
            // 同时也输出到 HBuilderX 的真实控制台，方便双端对照
            console.log(`[OppoHealth] ${msg}`);
        },

        // 1. 初始化 SDK
        doInit() {
            if (!oppoHealth) {
                this.appendLog('❌ 插件未加载，请确认混淆规则或 dcloud_uniplugins.json');
                return;
            }

            this.appendLog('▶️ 准备调用 initSdk...');
            try {
                oppoHealth.initSdk((res) => {
                    this.appendLog('✅ 初始化回调返回: ' + res);
                });
            } catch (e) {
                this.appendLog('❌ 调用 initSdk 出现 JS 异常: ' + e.message);
            }
        },

        // 2. 请求授权
        doAuth() {
            if (!oppoHealth) return this.appendLog('❌ 插件未加载');
            
            this.appendLog('▶️ 准备拉起授权页 requestAuth...');
            try {
                oppoHealth.requestAuth((code) => {
                    this.appendLog('⬇️ 收到授权回调，Code: ' + code);
                    if (code === 100000) {
                        this.appendLog('✅ 授权成功 (100000)');
                    } else if (code === 100007) {
                        this.appendLog('❌ 健康 app 未安装 (100007)');
                    } else if (code === 100014) {
                        this.appendLog('⚠️ 用户取消了授权 (100014)');
                    } else {
                        this.appendLog('❌ 授权失败，未知错误');
                    }
                });
            } catch (e) {
                this.appendLog('❌ 调用 requestAuth 出现 JS 异常: ' + e.message);
            }
        },

        // 3. 读取心率数据
        doReadHeartRate() {
            if (!oppoHealth) return this.appendLog('❌ 插件未加载');

            this.appendLog('▶️ 准备调用 readHeartRate...');
            try {
                oppoHealth.readHeartRate((res) => {
                    this.appendLog(`⬇️ 收到数据回调，类型: ${typeof res}`);
                    
                    if (typeof res === 'number') {
                        this.appendLog('❌ 读取失败，错误码: ' + res);
                    } else {
                        this.appendLog('✅ 读取成功，准备解析 JSON...');
                        this.heartRateData = res; 

                        try {
                            const dataObj = JSON.parse(res);
                            this.appendLog(`✅ JSON 解析成功，包含 ${dataObj.length || 0} 条数据点`);
                            // this.uploadToBackend(dataObj); // 先注释掉后端请求，专注跑通原生
                        } catch (e) {
                            this.appendLog('❌ JSON 解析失败: ' + e.message);
                        }
                    }
                });
            } catch (e) {
                this.appendLog('❌ 调用 readHeartRate 出现 JS 异常: ' + e.message);
            }
        }
    }
}
</script>

<style scoped>
.container {
    flex: 1;
    padding: 40rpx;
    background-color: #f5f5f5;
}

.title {
    font-size: 40rpx;
    font-weight: bold;
    text-align: center;
    margin-bottom: 50rpx;
    color: #333;
}

.btn-group {
    margin-bottom: 40rpx;
}

.btn {
    margin-bottom: 20rpx;
    font-size: 32rpx;
}

.log-box {
    height: 400rpx; /* 固定高度，方便滚动 */
    background-color: #ffffff;
    padding: 20rpx;
    border-radius: 12rpx;
    margin-bottom: 30rpx;
    border: 1px solid #ddd;
}

.log-title {
    font-size: 28rpx;
    font-weight: bold;
    color: #666;
    margin-bottom: 10rpx;
}

.log-content {
    font-size: 24rpx;
    color: #007aff;
    line-height: 1.5;
}

.data-box {
    flex: 1;
    background-color: #282c34;
    padding: 20rpx;
    border-radius: 12rpx;
}

.data-text {
    font-size: 24rpx;
    color: #98c379;
    font-family: monospace;
}
</style>