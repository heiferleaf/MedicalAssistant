<template>
    <view class="container">
        <text class="title">健康与用药 Agent - 数据同步</text>

        <view class="btn-group">
            <button class="btn" type="primary" @click="doInit">1. 初始化 OPPO SDK</button>
            <button class="btn" type="primary" @click="doAuth">2. 请求健康数据授权</button>
            <button class="btn" type="primary" @click="doReadHeartRate">3. 读取最近心率数据</button>
        </view>

        <scroll-view class="data-box" scroll-y="true">
            <text class="data-text">{{ heartRateData }}</text>
        </scroll-view>
    </view>
</template>

<script>
// 在全局作用域引入插件
const oppoHealth = uni.requireNativePlugin('OppoHealthModule');

export default {
    data() {
        return {
            heartRateData: '暂无数据'
        };
    },
    methods: {
        // 1. 初始化 SDK
        doInit() {
            if (!oppoHealth) {
                uni.showToast({ title: '插件未加载', icon: 'none' });
                return;
            }

            try {
                oppoHealth.initSdk((res) => {
                    console.log('初始化回调:', res);
                    uni.showToast({ title: '初始化调用完成', icon: 'none' });
                });
            } catch (e) {
                console.error('初始化异常:', e);
                uni.showToast({ title: '初始化发生异常', icon: 'none' });
            }
        },

        // 2. 请求授权
        doAuth() {
            if (!oppoHealth) {
                uni.showToast({ title: '插件未加载', icon: 'none' });
                return;
            }
            
            try {
                oppoHealth.requestAuth((code) => {
                    console.log('授权回调 Code:', code);
                    if (code === 100000) {
                        uni.showToast({ title: '授权成功', icon: 'success' });
                    } else if (code === 100007) {
                        uni.showToast({ title: '健康 App 未安装', icon: 'none' });
                    } else if (code === 100014) {
                        uni.showToast({ title: '用户取消授权', icon: 'none' });
                    } else {
                        uni.showToast({ title: '授权失败', icon: 'none' });
                    }
                });
            } catch (e) {
                console.error('授权异常:', e);
                uni.showToast({ title: '授权发生异常', icon: 'none' });
            }
        },

        // 3. 读取心率数据
        doReadHeartRate() {
            if (!oppoHealth) {
                uni.showToast({ title: '插件未加载', icon: 'none' });
                return;
            }

            uni.showLoading({ title: '读取中...' });
            try {
                oppoHealth.readHeartRate((res) => {
                    uni.hideLoading();
                    
                    if (typeof res === 'number') {
                        console.error('读取失败，错误码:', res);
                        uni.showToast({ title: '读取失败', icon: 'none' });
                    } else {
                        uni.showToast({ title: '读取成功', icon: 'success' });
                        this.heartRateData = res; 

                        try {
                            const dataObj = JSON.parse(res);
                            console.log(`JSON 解析成功，包含 ${dataObj.length || 0} 条数据点`);
                            // this.uploadToBackend(dataObj); // 需要时打开此处发送后端
                        } catch (e) {
                            console.error('JSON 解析失败:', e);
                        }
                    }
                });
            } catch (e) {
                uni.hideLoading();
                console.error('读取异常:', e);
                uni.showToast({ title: '读取发生异常', icon: 'none' });
            }
        }
    }
}
</script>

<style scoped>
.container {
    display: flex;
    flex-direction: column;
    height: 100vh; /* 确保占满屏幕，让 flex: 1 生效 */
    box-sizing: border-box;
    padding: 40rpx;
    background-color: #f5f5f5;
}

.title {
    font-size: 40rpx;
    font-weight: bold;
    text-align: center;
    margin-bottom: 50rpx;
    color: #333;
}

.btn-group {
    margin-bottom: 40rpx;
}

.btn {
    margin-bottom: 20rpx;
    font-size: 32rpx;
}

.data-box {
    flex: 1; /* 占据屏幕剩余的所有高度 */
    background-color: #282c34;
    padding: 20rpx;
    border-radius: 12rpx;
    overflow: hidden;
}

.data-text {
    font-size: 24rpx;
    color: #98c379;
    font-family: monospace;
    word-break: break-all; /* 防止长 JSON 字符串撑开宽度 */
}
</style>