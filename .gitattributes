# 告诉 Git 使用 LF 换行符（Linux/Unix 风格）
* text=auto eol=lf

# 确保所有文本文件使用 LF
*.java text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.json text eol=lf

# 二进制文件不处理
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
